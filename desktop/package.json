{
  "name": "lenverse-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electrobun shell that runs the LenVerse bun server and opens the modules home screen.",
  "scripts": {
    "start": "electrobun run",
    "dev": "electrobun dev",
    "dev:watch": "electrobun dev --watch",
    "build:dev": "bun install && electrobun build",
    "build:canary": "electrobun build --env=canary",
    "build:stable": "electrobun build --env=stable"
  },
  "dependencies": {
    "electrobun": "1.18.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
